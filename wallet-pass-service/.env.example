# Supabase (same project as the web app)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Apple Wallet — create at developer.apple.com (Pass Type ID + certificates)
APPLE_PASS_TYPE_IDENTIFIER=pass.com.yourorg.brotherhood
APPLE_TEAM_ID=
PASS_ORGANIZATION_NAME=Your Chapter

# PEM contents (use literal newlines, or single line with \n escapes)
WALLET_WWDR_PEM=
WALLET_SIGNER_CERT_PEM=
WALLET_SIGNER_KEY_PEM=
# WALLET_SIGNER_KEY_PASSPHRASE=

# Comma-separated web origins allowed to fetch passes (e.g. https://app.example.com,http://localhost:5173)
# Leave empty to allow any origin (convenient for local dev only).
ALLOWED_ORIGINS=http://localhost:5173

PORT=3333
