{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${title}",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "TextBlock",
      "text": "${subtitle}",
      "wrap": true,
      "spacing": "Small",
      "isSubtle": true
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Events",
      "url": "https://dsp.jacobtartabini.com/events"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Members",
      "url": "https://dsp.jacobtartabini.com/people"
    },
    {
      "type": "Action.OpenUrl",
      "title": "Home",
      "url": "https://dsp.jacobtartabini.com/"
    }
  ]
}
